CLOUDINARY_CLOUD_NAME = your_cloud_name
CLOUDINARY_API_KEY    = your_api_key
CLOUDINARY_API_SECRET = your_api_secret
MONGODB_URI           = mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Replace <username>, <password>, and <cluster> with your actual MongoDB credentials and cluster information.
MODEL_API_URL = https://your-model-api-url.com/detect
# Replace with the actual URL of your model API (e.g., Hugging Face Spaces endpoint).